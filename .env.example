VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini API key is stored as a Supabase Edge Function secret (GEMINI_API_KEY)
# Set it via: supabase secrets set GEMINI_API_KEY=your-key

# CORS origin for Edge Functions (REQUIRED for production)
# Set it via: supabase secrets set ALLOWED_ORIGIN=https://your-app-domain.com
# Defaults to '*' (allow all) if not set — must be restricted in production.
